{
  "name": "nexadesk",
  "version": "0.1.0",
  "private": true,
  "description": "Private incubation build of the NexaDesk multi-agent desktop workbench.",
  "author": "NexaDesk Contributors",
  "main": "apps/desktop/main.cjs",
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "brand:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-brand-assets.ps1",
    "dev:web": "npm run dev --workspace @nexadesk/web",
    "dev:server": "npm run dev --workspace @nexadesk/server",
    "build": "npm run build --workspaces --if-present",
    "build:server-bundle": "node scripts/build-server.mjs",
    "build:desktop": "npm run build && npm run build:server-bundle",
    "desktop": "npm run build:desktop && electron .",
    "desktop:smoke": "npm run build:desktop && node scripts/desktop-smoke.mjs",
    "desktop:retention-smoke": "npm run build:desktop && node scripts/desktop-retention-smoke.mjs",
    "desktop:packaged-smoke": "node scripts/packaged-smoke.mjs",
    "provider:matrix": "tsx scripts/provider-matrix-check.mjs",
    "provider:matrix:live": "tsx scripts/provider-matrix-check.mjs --live",
    "settings:smoke": "npm run build:server-bundle && node scripts/settings-persistence-smoke.mjs",
    "runtime:smoke": "npm run build:server-bundle && node scripts/runtime-state-smoke.mjs",
    "dist:win": "npm run build:desktop && electron-builder --win nsis --x64 --publish never",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . --max-warnings 80",
    "format": "prettier . --write",
    "format:check": "prettier --check eslint.config.js prettier.config.js scripts/desktop-smoke.mjs apps/web/src/lib/**/*.ts apps/server/src/automation-scheduler.ts apps/server/src/automation-scheduler.test.ts apps/server/src/server-utils.ts apps/server/src/runtime-state-store.ts apps/server/src/sqlite-store.ts apps/server/src/wesight-capabilities.ts",
    "test": "vitest run",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "rcedit": "^5.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.nexadesk.desktop",
    "productName": "NexaDesk",
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/after-pack.mjs",
    "files": [
      "apps/desktop/**/*",
      "apps/web/dist/**/*",
      "apps/server/dist/**/*",
      "build-resources/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build-resources/icon.ico",
      "legalTrademarks": "NexaDesk",
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico",
      "installerHeader": "build-resources/installer-header.bmp",
      "installerSidebar": "build-resources/installer-sidebar.bmp",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "NexaDesk",
      "uninstallDisplayName": "NexaDesk",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  }
}
